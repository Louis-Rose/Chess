{
  "manifest_version": 3,
  "name": "LUMNA Focus",
  "version": "0.9.1",
  "description": "Block distracting websites in your browser, managed from your LUMNA Focus list.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["declarativeNetRequest", "storage", "alarms", "tabs"],
  "host_permissions": ["https://lumna.co/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://lumna.co/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LUMNA Focus",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
