{
  "manifest_version": 3,
  "name": "LUMNA Focus",
  "version": "0.1.0",
  "description": "Blocks the sites on your LUMNA Focus list while focus mode is on.",
  "permissions": ["declarativeNetRequest", "storage", "alarms"],
  "host_permissions": [
    "https://lumna.co/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LUMNA Focus"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
