{
  "manifest_version": 3,
  "name": "LUMNA Focus",
  "version": "0.4.0",
  "description": "Blocks the sites on your LUMNA Focus list while focus mode is on.",
  "permissions": ["declarativeNetRequest", "storage", "alarms", "tabs"],
  "host_permissions": ["*://*/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://lumna.co/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LUMNA Focus"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
