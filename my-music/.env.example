# ─────────────────────────────────────────────────────────────────────────────
# My Music — configuration
#
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
#
# Create a Spotify app at https://developer.spotify.com/dashboard to obtain the
# CLIENT_ID and CLIENT_SECRET. In the app settings, add the Redirect URI below
# to the allow-list (it must match EXACTLY, including the trailing path).
# ─────────────────────────────────────────────────────────────────────────────

# From your Spotify developer dashboard:
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Must be registered in the Spotify app's "Redirect URIs". Spotify requires an
# explicit loopback IP (not "localhost") for this flow.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Filled in automatically by `auth_setup.py` after the one-time browser login.
# This is the long-lived credential the headless daemon uses.
SPOTIFY_REFRESH_TOKEN=

# ── Daemon tuning (sensible defaults; override only if you need to) ───────────

# How often to poll Spotify, in seconds.
POLL_INTERVAL_SECONDS=30

# A play is committed once EITHER threshold is met:
#   - it was actively played for at least this many milliseconds, OR
MIN_PLAY_MS=30000
#   - it reached at least this fraction of completion (0.0 - 1.0).
MIN_COMPLETION=0.80

# Backoff bounds (seconds) used when Spotify/network errors occur.
BACKOFF_BASE_SECONDS=5
BACKOFF_MAX_SECONDS=300

# ── Database (LUMNA's shared PostgreSQL) ─────────────────────────────────────
# The daemon writes the music_* tables that the public /music page reads. On
# the VM these match the LUMNA backend's DB_* settings. The schema itself is
# created by the backend; the daemon only writes rows.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumna
DB_USER=lumna
DB_PASSWORD=your_db_password_here
