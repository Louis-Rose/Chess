# Copy to .env and fill in, then: set -a; source .env; set +a; python worker.py
# (or export these in your shell)

# Where your LUMNA app lives
LUMNA_BASE_URL=https://lumna.co

# Shared secret — must match CLOTHING_WORKER_SECRET in the backend env on the VM.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CLOTHING_WORKER_SECRET=

# Optional tuning
CLOTHING_POLL_SECONDS=3
CLOTHING_ITEMS_PER_SOURCE=8
